Cell[BoxData[
 RowBox[{"newphasediag", ":=", 
  RowBox[{"Show", "[", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"ParametricPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"a", "-", " ", 
            RowBox[{
             RowBox[{"y", "^", "2"}], "/", "2"}]}], ",", "y"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"-", 
            RowBox[{"Sqrt", "[", "a", "]"}]}], ",", "2"}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"Ticks", "\[Rule]", "None"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "0", ",", "4", ",", "0.15"}], "}"}]}], "]"}], ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"ParametricPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "a"}], "+", " ", 
            RowBox[{
             RowBox[{"y", "^", "2"}], "/", "2"}]}], ",", 
           RowBox[{"-", "y"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"-", 
            RowBox[{"Sqrt", "[", "a", "]"}]}], ",", "2"}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"a", ",", "0", ",", "4", ",", "0.15"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"ParametricPlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "y"}], " ", 
           RowBox[{
            RowBox[{"Abs", "[", "y", "]"}], "/", "2"}]}], ",", "y"}], "}"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"Black", ",", 
           RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "}"}]}]}], "]"}], 
      "}"}]}], "]"}], "]"}]}]], "Input"],

