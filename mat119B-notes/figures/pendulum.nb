Cell[BoxData[
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", "t", "]"}], ",", 
         RowBox[{"Sin", "[", "t", "]"}], ",", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"k", "^", "2"}], "-", 
           RowBox[{
            RowBox[{"Sin", "[", 
             RowBox[{"t", "/", "2"}], "]"}], "^", "2"}]}], "]"}]}], "}"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"1", "/", "7"}], ",", 
         RowBox[{"9", "/", "7"}], ",", 
         RowBox[{"1", "/", "7"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cos", "[", "t", "]"}], ",", 
         RowBox[{"Sin", "[", "t", "]"}], ",", 
         RowBox[{"-", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"k", "^", "2"}], "-", 
            RowBox[{
             RowBox[{"Sin", "[", 
              RowBox[{"t", "/", "2"}], "]"}], "^", "2"}]}], "]"}]}]}], "}"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"1", "/", "7"}], ",", 
         RowBox[{"9", "/", "7"}], ",", 
         RowBox[{"1", "/", "7"}]}], "}"}]}], "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", 
     RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", "Thick"}], ",", 
   RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
   RowBox[{"Axes", "\[Rule]", "None"}], ",", 
   RowBox[{"ColorFunction", "\[Rule]", 
    RowBox[{"Function", "[", 
     RowBox[{"t", ",", 
      RowBox[{"Hue", "[", 
       RowBox[{"0", ",", "0", ",", 
        RowBox[{
         RowBox[{"1.9", "*", 
          RowBox[{"Cos", "[", "t", "]"}]}], "-", "1"}]}], "]"}]}], "]"}]}]}], 
  "]"}]], "Input",
